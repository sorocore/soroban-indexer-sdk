# Soroban RPC endpoint (testnet default)
RPC_URL=https://soroban-testnet.stellar.org:443

# Network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/soroban_indexer

# Ledger to begin indexing from (0 = from genesis, or set a specific sequence)
START_LEDGER=1

# API server port
PORT=3000

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
